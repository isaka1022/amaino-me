# GitHub OAuth (管理画面の認証用)
# https://github.com/settings/developers で OAuth App を作成
# Callback URL: https://amaino.me/api/auth/callback (本番)
# Callback URL: http://localhost:4321/api/auth/callback (ローカル開発)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Airtable (フォーム送信 / メールリスト・フィードバック)
AIRTABLE_PERSONAL_ACCESS_TOKEN=your_airtable_pat
AIRTABLE_BASE_ID=your_airtable_base_id
