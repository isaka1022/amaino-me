---
interface Props {
  articlePath: string;
  articleTitle: string;
}

const { articlePath, articleTitle } = Astro.props;
---

<div class="not-prose flex justify-center my-8">
  <button
    id="like-button"
    class="btn btn-ghost border border-base-300 gap-2 text-base-content/70 hover:border-red-300 hover:text-red-500 transition-colors"
    aria-label="いいね"
  >
    <svg
      id="like-heart"
      class="size-5 transition-all"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"
      />
    </svg>
    <span id="like-label">いいね</span>
  </button>
</div>

<script define:vars={{ articlePath, articleTitle }}>
  (function () {
    const STORAGE_KEY = 'like_' + articlePath;
    const btn = document.getElementById('like-button');
    const heart = document.getElementById('like-heart');
    const label = document.getElementById('like-label');

    function setLiked() {
      if (!btn || !heart || !label) return;
      btn.disabled = true;
      btn.classList.add('btn-disabled', 'opacity-100');
      btn.classList.remove('hover:border-red-300', 'hover:text-red-500');
      btn.classList.add('text-red-500', 'border-red-200');
      heart.setAttribute('fill', '#ef4444');
      heart.setAttribute('stroke', '#ef4444');
      label.textContent = 'いいね済み';
    }

    // 初期状態をlocalStorageから復元
    try {
      if (localStorage.getItem(STORAGE_KEY) === '1') {
        setLiked();
        return;
      }
    } catch (_) {}

    if (!btn) return;

    btn.addEventListener('click', async function () {
      btn.disabled = true;

      try {
        const res = await fetch('/api/like', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ articlePath, articleTitle }),
        });

        if (res.ok) {
          try { localStorage.setItem(STORAGE_KEY, '1'); } catch (_) {}
          setLiked();

          if (typeof gtag === 'function') {
            gtag('event', 'article_like', {
              page_path: articlePath,
              page_title: document.title,
            });
          }
        } else {
          // 失敗時はボタンを戻す
          btn.disabled = false;
        }
      } catch (_) {
        btn.disabled = false;
      }
    });
  })();
</script>
