---
interface Props {
  articleTitle: string;
  articlePath: string;
}
const { articleTitle, articlePath } = Astro.props;
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

const IMPROVEMENTS = [
  { value: "more_examples", label: "もっと具体例がほしかった" },
  { value: "deeper", label: "もっと深く掘り下げてほしかった" },
  { value: "basics", label: "前提知識の説明が不足していた" },
  { value: "nothing", label: "特になし" },
] as const;
---

<dialog id="read-survey-modal" class="modal">
  <div class="modal-box max-w-sm">
    <h3 class="font-bold text-lg mb-1">読了ありがとうございます！</h3>
    <p class="text-sm text-base-content/60 mb-5">よければ感想を教えてください（30秒）</p>

    <!-- 満足度 -->
    <div class="mb-5">
      <p class="text-sm font-medium mb-2">この記事の満足度は？</p>
      <div class="rating rating-lg gap-1" id="survey-rating">
        {[1, 2, 3, 4, 5].map((n) => (
          <input
            type="radio"
            name="survey-rating"
            class="mask mask-star-2 bg-warning"
            value={String(n)}
            aria-label={`${n}点`}
          />
        ))}
      </div>
    </div>

    <!-- 物足りなかった点 -->
    <div class="mb-5">
      <p class="text-sm font-medium mb-2">記事で物足りなかった点は？</p>
      <div class="flex flex-col gap-2" id="survey-improvements">
        {IMPROVEMENTS.map(({ value, label }) => (
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="survey-improvement" value={value} class="radio radio-sm" />
            <span class="text-sm">{label}</span>
          </label>
        ))}
      </div>
    </div>

    <!-- Honeypot: BOT 対策（人間には見えない） -->
    <input
      type="text"
      id="survey-honeypot"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;"
    />

    <!-- Turnstile invisible widget -->
    {siteKey && (
      <div
        id="survey-turnstile"
        data-sitekey={siteKey}
      ></div>
    )}

    <!-- アクション -->
    <div id="survey-actions" class="flex gap-2 justify-end">
      <button id="survey-skip" class="btn btn-ghost btn-sm">スキップ</button>
      <button id="survey-submit" class="btn btn-primary btn-sm" disabled>送信する</button>
    </div>

    <!-- 送信後メッセージ -->
    <div id="survey-done" class="hidden text-center py-2">
      <p class="text-sm font-medium">ありがとうございました！🎉</p>
      <button id="survey-close" class="btn btn-ghost btn-sm mt-2">閉じる</button>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script define:vars={{ articleTitle, articlePath }}>
  (function () {
    const STORAGE_KEY = "survey_shown_" + articlePath;

    function isAlreadyShown() {
      try {
        return !!sessionStorage.getItem(STORAGE_KEY);
      } catch (_) {
        return false;
      }
    }

    function markShown() {
      try {
        sessionStorage.setItem(STORAGE_KEY, "1");
      } catch (_) {}
    }

    function sendGa(eventName) {
      if (typeof gtag === "function") {
        gtag("event", eventName, {
          page_path: articlePath,
          page_title: articleTitle,
        });
      }
    }

    const modal = /** @type {HTMLDialogElement} */ (
      document.getElementById("read-survey-modal")
    );
    const submitBtn = document.getElementById("survey-submit");
    const skipBtn = document.getElementById("survey-skip");
    const closeBtn = document.getElementById("survey-close");
    const actions = document.getElementById("survey-actions");
    const doneMsg = document.getElementById("survey-done");
    const turnstileEl = document.getElementById("survey-turnstile");

    // Turnstile invisible widget のレンダリング
    let surveyTurnstileId = null;
    function renderSurveyTurnstile() {
      if (!window.turnstile || !turnstileEl || surveyTurnstileId !== null) return;
      const siteKey = turnstileEl.dataset.sitekey;
      if (!siteKey) return;
      surveyTurnstileId = window.turnstile.render(turnstileEl, {
        sitekey: siteKey,
        size: "invisible",
        callback: (token) => {
          doSubmit(token);
        },
        "error-callback": () => {
          doSubmit("");
        },
      });
    }

    // Turnstile JS が読み込み済みでなければ読み込む（EmailSubscribeForm と共用）
    if (!document.getElementById("turnstile-script")) {
      const script = document.createElement("script");
      script.id = "turnstile-script";
      script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit";
      script.async = true;
      script.defer = true;
      script.onload = renderSurveyTurnstile;
      document.head.appendChild(script);
    } else {
      // 既に読み込まれている場合はすぐにレンダリング
      renderSurveyTurnstile();
    }

    document.querySelectorAll('input[name="survey-improvement"]').forEach((el) => {
      el.addEventListener("change", updateSubmitState);
    });

    document.querySelectorAll('input[name="survey-rating"]').forEach((el) => {
      el.addEventListener("change", updateSubmitState);
    });

    function updateSubmitState() {
      const hasRating = !!document.querySelector('input[name="survey-rating"]:checked');
      const hasImprovement = !!document.querySelector('input[name="survey-improvement"]:checked');
      submitBtn.disabled = !(hasRating && hasImprovement);
    }

    async function doSubmit(turnstileToken) {
      const ratingEl = document.querySelector('input[name="survey-rating"]:checked');
      const improvementEl = document.querySelector('input[name="survey-improvement"]:checked');
      if (!ratingEl || !improvementEl) return;

      const rating = parseInt(ratingEl.value, 10);
      const improvement = improvementEl.value;
      const website = document.getElementById("survey-honeypot")?.value ?? "";

      try {
        await fetch("/api/survey", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ articlePath, articleTitle, rating, improvement, website, turnstileToken }),
        });
      } catch (_) {
        // 送信失敗してもUIは完了にする（ユーザー体験を損なわない）
      }

      sendGa("survey_submitted");
      actions.classList.add("hidden");
      doneMsg.classList.remove("hidden");
    }

    submitBtn.addEventListener("click", () => {
      submitBtn.disabled = true;
      submitBtn.textContent = "送信中...";

      if (window.turnstile && surveyTurnstileId !== null) {
        // Turnstile のコールバックで doSubmit が呼ばれる
        window.turnstile.execute(surveyTurnstileId);
      } else {
        // Turnstile 未設定（開発環境等）はそのまま送信
        doSubmit("");
      }
    });

    skipBtn.addEventListener("click", () => {
      modal.close();
      markShown();
    });

    closeBtn.addEventListener("click", () => {
      modal.close();
    });

    // backdrop クリックで閉じた場合も記録
    modal.addEventListener("close", () => {
      markShown();
    });

    // PostLayout のスクロール検知から呼ばれる
    window.__openReadSurvey = function () {
      if (isAlreadyShown()) return;
      markShown();
      sendGa("survey_shown");
      modal.showModal();
    };
  })();
</script>
