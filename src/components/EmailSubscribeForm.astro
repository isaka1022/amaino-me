---
export interface Props {
  title?: string;
  compact?: boolean;
  source?: string;
}
const { title = "メールで更新を受け取る", compact = false, source = "amaino.me" } = Astro.props;
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<div class={`email-subscribe-form not-prose${compact ? " compact" : ""}`}>
  <p class="text-sm text-base-content/60 mb-3">{title}</p>
  <form class="subscribe-form flex flex-col gap-2" data-source={source}>
    {!compact && (
      <input
        type="text"
        name="name"
        placeholder="お名前"
        class="input input-bordered input-sm w-full"
        autocomplete="name"
      />
    )}
    <input
      type="email"
      name="email"
      placeholder="メールアドレス"
      required
      class="input input-bordered input-sm w-full"
      autocomplete="email"
    />
    <!-- Honeypot: BOT 対策（人間には見えない） -->
    <input
      type="text"
      name="website"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;"
    />
    <!-- Turnstile widget -->
    {siteKey && (
      <div
        class="cf-turnstile-widget"
        data-sitekey={siteKey}
      ></div>
    )}
    <button type="submit" class="btn btn-primary btn-sm w-full">
      登録する
    </button>
    <p class="subscribe-msg text-xs text-center hidden"></p>
  </form>
</div>

<script>
  declare global {
    interface Window {
      turnstile?: {
        render: (container: string | HTMLElement, options: Record<string, unknown>) => string;
        reset: (widgetId: string) => void;
        remove: (widgetId: string) => void;
        getResponse: (widgetId: string) => string | undefined;
      };
    }
  }

  // Turnstile を explicit モードで管理するための Map（widgetId）
  const widgetIds = new WeakMap<HTMLElement, string>();

  function renderTurnstileWidgets() {
    if (!window.turnstile) return;
    document.querySelectorAll<HTMLElement>(".cf-turnstile-widget").forEach((el) => {
      if (widgetIds.has(el)) return; // 既にレンダリング済み
      const siteKey = el.dataset.sitekey;
      if (!siteKey) return;
      const id = window.turnstile!.render(el, {
        sitekey: siteKey,
        theme: "light",
        size: "flexible",
      });
      widgetIds.set(el, id);
    });
  }

  function initSubscribeForms() {
    renderTurnstileWidgets();

    document.querySelectorAll<HTMLFormElement>(".subscribe-form").forEach((form) => {
      if (form.dataset.initialized) return;
      form.dataset.initialized = "true";

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const btn = form.querySelector<HTMLButtonElement>("button[type=submit]")!;
        const msg = form.querySelector<HTMLParagraphElement>(".subscribe-msg")!;
        const email = (form.querySelector<HTMLInputElement>('input[name="email"]')?.value ?? "").trim();
        const nameEl = form.querySelector<HTMLInputElement>('input[name="name"]');
        const name = nameEl ? nameEl.value.trim() : undefined;
        const source = form.dataset.source || "amaino.me";
        const website = form.querySelector<HTMLInputElement>('input[name="website"]')?.value ?? "";

        // Turnstile トークンを取得
        const widgetEl = form.querySelector<HTMLElement>(".cf-turnstile-widget");
        const widgetId = widgetEl ? widgetIds.get(widgetEl) : undefined;
        const turnstileToken = widgetId ? (window.turnstile?.getResponse(widgetId) ?? "") : "";

        btn.disabled = true;
        btn.textContent = "送信中...";
        msg.classList.add("hidden");

        try {
          const res = await fetch("/api/subscribe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, source, website, turnstileToken, ...(name ? { name } : {}) }),
          });
          const data = await res.json();
          if (data.ok) {
            form.reset();
            // Turnstile をリセット
            if (widgetId) window.turnstile?.reset(widgetId);
            msg.textContent = "登録しました！ありがとうございます。";
            msg.classList.remove("hidden", "text-error");
            msg.classList.add("text-success");
          } else {
            throw new Error(data.error);
          }
        } catch {
          msg.textContent = "エラーが発生しました。もう一度お試しください。";
          msg.classList.remove("hidden", "text-success");
          msg.classList.add("text-error");
          btn.disabled = false;
          btn.textContent = "登録する";
        }
      });
    });
  }

  // Turnstile JS が読み込まれたら explicit render
  function loadTurnstileScript() {
    if (document.getElementById("turnstile-script")) return;
    const script = document.createElement("script");
    script.id = "turnstile-script";
    script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit";
    script.async = true;
    script.defer = true;
    script.onload = renderTurnstileWidgets;
    document.head.appendChild(script);
  }

  initSubscribeForms();
  loadTurnstileScript();
  document.addEventListener("astro:page-load", () => {
    initSubscribeForms();
    renderTurnstileWidgets();
  });
</script>
