---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { SITE_URL } from "../config";
---

<BaseLayout
  title="プロジェクト一覧"
  description="井上周（Amane Inoue）が取り組んでいるプロジェクトの一覧です。"
  canonical={`${SITE_URL}/projects`}
  keywords={["プロジェクト", "Amane Inoue", "Astro", "AI"]}
  sideBarActiveItemID="projects"
>
  <div>
    <div class="text-2xl w-full font-bold mb-5">Projects</div>
  </div>

  <HorizontalCard
    title="amaino.me"
    img="/post_img.webp"
    desc="このサイトです。Astro + TailwindCSS + Vercelで構築したパーソナルサイト。"
    url="https://amaino.me"
    badge="NOW"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="note.com/amaino"
    img="/post_img.webp"
    desc="健康・AI・マラソン・ノマドライフについて129記事を発信中。"
    url="https://note.com/amaino"
  />
</BaseLayout>
