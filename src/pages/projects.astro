---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { SITE_URL } from "../config";
---

<BaseLayout
  title="プロジェクト一覧"
  description="井上周（Amane Inoue）が取り組んでいるプロジェクトの一覧です。"
  canonical={`${SITE_URL}/projects`}
  keywords={["プロジェクト", "Amane Inoue", "Astro", "AI"]}
  sideBarActiveItemID="projects"
>
  <div>
    <div class="text-2xl w-full font-bold mb-5">Projects</div>
  </div>

  <HorizontalCard
    title="amaino.me"
    img="/post_img.webp"
    desc="このサイトです。Astro + TailwindCSS + Vercelで構築したパーソナルサイト。"
    url="https://amaino.me"
    badge="NOW"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="note.com/amaino"
    img="/post_img.webp"
    desc="健康・AI・マラソン・ノマドライフについて129記事を発信中。"
    url="https://note.com/amaino"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="読んだ本が記憶に残るサービス"
    img="/post_img.webp"
    desc="AIが本の要点を抽出・整理し、あとから検索できる読書メモサービス。先行登録受付中。"
    url="/lp/book-summary/"
    badge="CONCEPT"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="知識系ニュースレター"
    img="/post_img.webp"
    desc="理系・知識系コンテンツを週1で届けるニュースレター。先行登録受付中。"
    url="/lp/newsletter/"
    badge="CONCEPT"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="理系進路・院試相談"
    img="/post_img.webp"
    desc="他大院試・研究室選び・浪人か進学かなど、理系進路の悩みに答える個別相談。先行相談枠受付中。"
    url="/lp/study-consult/"
    badge="CONCEPT"
  />
</BaseLayout>
