---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  <HorizontalCard
    title="amaino.me"
    img="/post_img.webp"
    desc="このサイトです。Astro + TailwindCSS + Cloudflare Pagesで構築したパーソナルサイト。"
    url="https://amaino.me"
    badge="NOW"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="note.com/amaino"
    img="/post_img.webp"
    desc="健康・AI・マラソン・ノマドライフについて129記事を発信中。"
    url="https://note.com/amaino"
  />
</BaseLayout>
