---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Services" sideBarActiveItemID="services">
  <div>
    <div class="text-3xl w-full font-bold mb-2">Services</div>
    <p class="text-lg mb-5">お気軽にお問い合わせください。</p>
  </div>

  <HorizontalCard
    title="精密栄養カウンセリング"
    img="/post_img.webp"
    desc="遺伝子検査・腸内フローラ解析をベースに、あなた専用の栄養プランを設計します。ダイエット、体質改善、パフォーマンス向上に。"
    url="https://note.com/amaino"
    badge="受付中"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="AI導入コンサルティング"
    img="/post_img.webp"
    desc="ChatGPT / Claude等のLLMを業務に導入するための戦略設計・プロトタイプ開発・社内研修を提供します。"
    url="https://note.com/amaino"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="AI講師・セミナー"
    img="/post_img.webp"
    desc="非エンジニア向けのAI活用講座。生成AIの基礎から実践的なプロンプトエンジニアリングまで。"
    url="https://note.com/amaino"
  />
</BaseLayout>
