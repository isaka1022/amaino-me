---
import { type CollectionEntry, getCollection, render } from "astro:content";
import type { BlogSchema } from "../../content.config";
import PostLayout from "../../layouts/PostLayout.astro";

export async function getStaticPaths() {
  // unlisted記事もページ生成するため、draftのみ除外
  const allGeneratedPosts = await getCollection("blog", ({ data }) => !data.draft);
  allGeneratedPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  // 一覧系（前後ナビ・関連記事）はunlistedも除外
  const listedPosts = allGeneratedPosts.filter((p) => !p.data.unlisted);

  return allGeneratedPosts.map((entry) => {
    const listedIndex = listedPosts.findIndex((p) => p.id === entry.id);
    const isListed = listedIndex !== -1;

    return {
      params: { slug: entry.id },
      props: {
        entry,
        prevPost: isListed ? (listedPosts[listedIndex + 1] ?? null) : null,
        nextPost: isListed ? (listedPosts[listedIndex - 1] ?? null) : null,
        allPosts: listedPosts,
      },
    };
  });
}

interface Props {
  entry: CollectionEntry<"blog">;
  prevPost: CollectionEntry<"blog"> | null;
  nextPost: CollectionEntry<"blog"> | null;
  allPosts: CollectionEntry<"blog">[];
}

const { entry, prevPost, nextPost, allPosts } = Astro.props;
const post: BlogSchema = entry.data;
const { Content, headings } = await render(entry);

const rawBody = entry.body ?? "";
const charCount = rawBody.replace(/\s+/g, "").length;
const readingTimeMin = Math.max(1, Math.round(charCount / 500));

const currentTags = entry.data.tags ?? [];
const relatedPosts = allPosts
  .filter((p) => p.id !== entry.id)
  .map((p) => {
    let score = 0;
    if (p.data.category === entry.data.category) score += 2;
    const pTags = p.data.tags ?? [];
    score += currentTags.filter((t) => pTags.includes(t)).length * 3;
    return { post: p, score };
  })
  .filter((r) => r.score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 6)
  .map((r) => r.post);
---

<PostLayout
  title={post.title}
  description={post.description}
  pubDate={post.pubDate}
  heroImage={post.heroImage}
  updatedDate={post.updatedDate}
  badge={post.badge}
  tags={post.tags}
  category={post.category}
  headings={headings}
  readingTimeMin={readingTimeMin}
  prevPost={prevPost ? { title: prevPost.data.title, url: `/blog/${prevPost.id}` } : null}
  nextPost={nextPost ? { title: nextPost.data.title, url: `/blog/${nextPost.id}` } : null}
  relatedPosts={relatedPosts.map((p) => ({ title: p.data.title, url: `/blog/${p.id}`, pubDate: p.data.pubDate }))}
  source={post.source}
  originalUrl={post.originalUrl}
  noindex={entry.data.unlisted}
>
  <Content />
</PostLayout>
