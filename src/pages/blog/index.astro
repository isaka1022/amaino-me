---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalCard from "../../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import { SITE_URL } from "../../config";

const CATEGORY_LABELS: Record<string, string> = {
  tech: "テック",
  book: "書籍",
  travel: "旅行",
  "university-life": "大学生活",
  "life-style": "ライフスタイル",
  movie: "映画",
  drama: "ドラマ",
  photo: "写真",
  event: "イベント",
  "how-to-study": "勉強法",
  "drive-blog": "ブログ運営",
  programming: "プログラミング",
  development: "開発",
  uncategorized: "その他",
};

const posts = await getCollection("blog", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryCounts = new Map<string, number>();
for (const post of posts) {
  const cat = post.data.category ?? "uncategorized";
  categoryCounts.set(cat, (categoryCounts.get(cat) ?? 0) + 1);
}
const sortedCategories = [...categoryCounts.entries()].sort((a, b) => b[1] - a[1]);

const PAGE_SIZE = 10;
const totalPages = Math.ceil(posts.length / PAGE_SIZE);
const currentPosts = posts.slice(0, PAGE_SIZE);
---

<BaseLayout
  title="ブログ記事一覧"
  description="AI、LLM/RAG、健康、マラソン、ライフスタイルに関する記事一覧です。"
  canonical={`${SITE_URL}/blog/`}
  keywords={["AI", "LLM", "RAG", "健康", "マラソン", "ブログ"]}
  sideBarActiveItemID="blog"
>
  <div class="mb-5">
    <div class="text-2xl w-full font-bold">Blog</div>
  </div>

  <div class="flex flex-wrap gap-2 mb-8">
    {sortedCategories.map(([cat, count]) => (
      <a
        href={`/blog/category/${cat}`}
        class="badge badge-lg badge-outline hover:badge-primary transition-colors gap-1 no-underline"
      >
        {CATEGORY_LABELS[cat] ?? cat}
        <span class="text-xs opacity-60">({count})</span>
      </a>
    ))}
  </div>

  {
    currentPosts.length === 0 ? (
      <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
        <p class="font-bold">Sorry!</p>
        <p>There are no blog posts to show at the moment. Check back later!</p>
      </div>
    ) : (
      <ul>
        {currentPosts.map((post) => (
          <>
            <HorizontalCard
              title={post.data.title}
              img={post.data.heroImage}
              desc={post.data.description}
              url={"/blog/" + post.id}
              target="_self"
              badge={post.data.badge}
              tags={post.data.tags}
            />
            <div class="divider my-0" />
          </>
        ))}
      </ul>
    )
  }

  <div class="flex justify-between">
    <div />
    {
      totalPages > 1 && (
        <a href="/blog/page/2" class="btn btn-ghost my-10 mx-5">
          古い記事
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
          </svg>
        </a>
      )
    }
  </div>
</BaseLayout>
