---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import { SITE_URL } from "../config";
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
---

<BaseLayout
  title="Amane Inoue | AI・健康・ランニング"
  description="井上周（Amane Inoue）の公式サイト。AIエンジニアリング、LLM/RAG、健康、マラソンに関する発信を行っています。"
  canonical={`${SITE_URL}/`}
  keywords={["井上周", "Amane Inoue", "AI", "LLM", "RAG", "健康", "マラソン"]}
  sideBarActiveItemID="home"
>
  <div class="pb-12 mt-5">
    <div class="text-sm text-base-content/60 mb-1">こんにちは</div>
    <div class="text-3xl font-bold">井上 周</div>
    <div class="text-xl py-2 text-base-content/80">つなげていく、つながっていく</div>
    <div class="py-2">
      <p class="text-base leading-relaxed">
        ソフトウェアエンジニア / 精密栄養カウンセラー / アドベンチャーランナー。
        テクノロジーと健康を軸に、人と人、知識と実践をつなげる活動をしています。
        スペイン移住に向けて準備中。
      </p>
    </div>
    <div class="mt-6">
      <a class="btn btn-sm" href="/about">About me</a>
      <a href="/blog/" class="btn btn-sm btn-outline ml-3">
        Blog
      </a>
    </div>
  </div>

  <div>
    <div class="text-xl w-full font-bold mb-5 mt-10">最新の記事</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + post.id}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
